# Copy to `.env` and adjust. Loaded automatically when python-dotenv is installed.

# Comma-separated list of frontend origins (no trailing slashes).
# Required if your UI uses fetch/credentials or you deploy to HTTPS.
# Examples:
#   EDUADAPT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
#   EDUADAPT_CORS_ORIGINS=https://your-app.vercel.app
# Recommended for local Next.js (port 3000):
EDUADAPT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Leave unset only for quick tests (any origin, credentials disabled).
# EDUADAPT_CORS_ORIGINS=

# Optional: richer mistake explanations and coaching text (never used for scoring).
# LLM_API_KEY=
